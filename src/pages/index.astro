---
import Layout from "../layouts/Layout.astro";
import SideNav from "../components/SideNav.tsx";
import SocialLinks from "../components/SocialLinks.astro";
import About from "../components/About.astro";
import ExperienceSection from "../components/ExperienceSection.astro";
import ProjectsSection from "../components/ProjectsSection.astro";

import "../styles/global.css";
---

<Layout>
	<div class="mx-auto min-h-screen max-w-[84rem] px-6 md:px-12 lg:px-24">
		<div class="lg:flex lg:justify-between lg:gap-4">
			<!-- LEFT / STICKY HEADER -->
			<header
				class="flex flex-col justify-between py-12 lg:sticky lg:top-0 lg:max-h-screen lg:w-[48%] lg:py-24"
			>
				<div>
					<h1
						class="font-display text-4xl font-bold tracking-tight text-stone-200 sm:text-5xl"
					>
						Josh Cemine
					</h1>
					<h2
						class="mt-3 text-lg font-medium tracking-tight text-stone-200"
					>
						Fullstack Developer
					</h2>
					<p class="mt-4 max-w-xs leading-normal">
						I build fast, reliable web applications end to end,
						from the data layer to the deployed UI.
					</p>

					<SideNav client:load />
				</div>

				<div class="mt-8 flex items-center gap-5">
					<SocialLinks />
				</div>
			</header>

			<!-- RIGHT / SCROLLING CONTENT -->
			<main class="lg:w-[52%] lg:py-24">
				<About />
				<ExperienceSection />
				<ProjectsSection />

				<footer class="max-w-md pb-16 text-sm text-stone-500">
					<p>
						Loosely designed after
						<a
							href="https://brittanychiang.com/"
							target="_blank"
							rel="noopener noreferrer"
							class="font-medium text-stone-400 hover:text-amber-300"
							>Brittany Chiang's</a
						> portfolio. Built with
						<a
							href="https://astro.build/"
							target="_blank"
							rel="noopener noreferrer"
							class="font-medium text-stone-400 hover:text-amber-300"
							>Astro</a
						>, Preact, and Tailwind CSS, deployed on Oracle Cloud
						behind Nginx. Text set in Inter.
					</p>
				</footer>
			</main>
		</div>
	</div>
</Layout>
