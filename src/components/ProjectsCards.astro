---
import type { Project } from "../data/data";
const { project } = Astro.props as { project: Project };
---

<a
    href={project.link}
    target="_blank"
    rel="noopener noreferrer"
    class="glass-white gborder-white gshadow rounded-md flex flex-col w-full"
>
    <!-- Image container; glass brown fade when no picture yet -->
    {
        project.image ? (
            <div
                class="h-40 md:h-42 w-full overflow-hidden bg-center bg-cover rounded-t-md"
                style={`background-image: url(${project.image});`}
            />
        ) : (
            <div class="h-40 md:h-42 w-full rounded-t-md glass-fade-brown" />
        )
    }

    <!-- Content container -->
    <div class="flex flex-col justify-between p-3 text-white/90 h-full">
        <div>
            <h3 class="font-bold text-lg md:text-xl">{project.title}</h3>
            <p class="mb-2 text-sm md:text-base">{project.description}</p>
        </div>

        <!-- Tags container -->
        <div class="flex flex-wrap gap-1 mt-auto">
            {
                project.tags.map((tag) => (
                    <span class="text-[0.55rem] md:text-xs px-2 py-1 bg-[#2D2327]/80 rounded-md">
                        {tag}
                    </span>
                ))
            }
        </div>
    </div>
</a>
