---
import { jobs, education } from "../data/data";
import Resume from "/src/assets/Resume.pdf";
---

<section
    id="experience"
    class="mb-16 scroll-mt-16 md:mb-24 lg:mb-36 lg:scroll-mt-24"
>
    <div
        class="sticky top-0 z-20 -mx-6 mb-4 w-screen bg-[#1C1518]/75 px-6 py-5 backdrop-blur md:-mx-12 md:px-12 lg:sr-only"
    >
        <h2 class="text-sm font-bold uppercase tracking-widest text-stone-200">
            Experience
        </h2>
    </div>

    <ol class="group/list">
        {
            jobs.map((job) => (
                <li class="mb-12">
                    <div class="group relative grid pb-1 transition-all sm:grid-cols-10 sm:gap-8 md:gap-6 lg:hover:!opacity-100 lg:group-hover/list:opacity-50">
                        <div class="absolute -inset-x-4 -inset-y-4 z-0 hidden rounded-md transition lg:-inset-x-6 lg:block lg:group-hover:bg-white/5 lg:group-hover:drop-shadow-lg" />
                        <header class="z-10 mb-2 mt-1 text-xs font-semibold uppercase tracking-wide text-stone-500 sm:col-span-3">
                            {job.period}
                        </header>
                        <div class="z-10 sm:col-span-7">
                            <h3 class="font-medium leading-snug text-stone-200">
                                {job.company}
                            </h3>
                            <p class="text-sm text-stone-500">{job.role}</p>

                            {job.bullets && (
                                <ul class="mt-2 list-disc space-y-1 pl-4 text-sm leading-normal marker:text-stone-600">
                                    {job.bullets.map((bullet) => (
                                        <li>{bullet}</li>
                                    ))}
                                </ul>
                            )}

                            {job.subsections &&
                                job.subsections.map((sub) => (
                                    <div class="mt-4">
                                        <h4 class="text-sm font-semibold text-stone-300">
                                            {sub.title}{" "}
                                            <span class="font-normal text-stone-500">
                                                · {sub.role}
                                            </span>
                                        </h4>
                                        <ul class="mt-1 list-disc space-y-1 pl-4 text-sm leading-normal marker:text-stone-600">
                                            {sub.bullets.map((bullet) => (
                                                <li>{bullet}</li>
                                            ))}
                                        </ul>
                                        {sub.tags && (
                                            <ul
                                                class="flex flex-wrap"
                                                aria-label="Technologies used"
                                            >
                                                {sub.tags.map((tag) => (
                                                    <li class="mr-1.5 mt-2">
                                                        <div class="flex items-center rounded-full bg-amber-400/10 px-3 py-1 text-xs font-medium leading-5 text-amber-300">
                                                            {tag}
                                                        </div>
                                                    </li>
                                                ))}
                                            </ul>
                                        )}
                                    </div>
                                ))}

                            {job.tags.length > 0 && (
                                <ul
                                    class="mt-3 flex flex-wrap"
                                    aria-label="Technologies used"
                                >
                                    {job.tags.map((tag) => (
                                        <li class="mr-1.5 mt-2">
                                            <div class="flex items-center rounded-full bg-amber-400/10 px-3 py-1 text-xs font-medium leading-5 text-amber-300">
                                                {tag}
                                            </div>
                                        </li>
                                    ))}
                                </ul>
                            )}
                        </div>
                    </div>
                </li>
            ))
        }
    </ol>

    <!-- EDUCATION -->
    <h3
        class="mb-6 mt-16 text-sm font-bold uppercase tracking-widest text-stone-200"
    >
        Education
    </h3>
    <ol class="group/list">
        {
            education.map((entry) => (
                <li class="mb-10">
                    <div class="group relative grid pb-1 transition-all sm:grid-cols-10 sm:gap-8 md:gap-6 lg:hover:!opacity-100 lg:group-hover/list:opacity-50">
                        <div class="absolute -inset-x-4 -inset-y-4 z-0 hidden rounded-md transition lg:-inset-x-6 lg:block lg:group-hover:bg-white/5 lg:group-hover:drop-shadow-lg" />
                        <header class="z-10 mb-2 mt-1 text-xs font-semibold uppercase tracking-wide text-stone-500 sm:col-span-3">
                            {entry.period}
                        </header>
                        <div class="z-10 sm:col-span-7">
                            <h4 class="font-medium leading-snug text-stone-200">
                                {entry.institution}
                            </h4>
                            <p class="text-sm text-stone-500">
                                {entry.degree}
                            </p>
                            {entry.achievements.length > 0 && (
                                <ul class="mt-2 list-disc space-y-1 pl-4 text-sm leading-normal marker:text-stone-600">
                                    {entry.achievements.map((item) => (
                                        <li>{item}</li>
                                    ))}
                                </ul>
                            )}
                        </div>
                    </div>
                </li>
            ))
        }
    </ol>

    <a
        class="group mt-4 inline-flex items-center font-medium leading-tight text-stone-200 hover:text-amber-300"
        href={Resume}
        download="Josh_Cemine_Resume.pdf"
    >
        <span class="border-b border-transparent pb-px transition group-hover:border-amber-300">
            View Full Résumé
        </span>
        <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
            fill="currentColor"
            class="ml-1 h-4 w-4 shrink-0 transition-transform group-hover:translate-y-0.5"
            aria-hidden="true"
        >
            <path
                fill-rule="evenodd"
                d="M10 3a.75.75 0 01.75.75v9.638l3.96-4.158a.75.75 0 111.08 1.04l-5.25 5.5a.75.75 0 01-1.08 0l-5.25-5.5a.75.75 0 111.08-1.04l3.96 4.158V3.75A.75.75 0 0110 3z"
                clip-rule="evenodd"></path>
        </svg>
    </a>
</section>
